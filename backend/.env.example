# LLM HUD Backend Configuration
# Copy this to .env and adjust as needed

# Server
HOST=127.0.0.1
PORT=8000

# Database (SQLite by default; swap for PostgreSQL when ready to go cloud)
# SQLite:     sqlite+aiosqlite:///./llm_hud.db
# PostgreSQL: postgresql+asyncpg://user:password@host:5432/llm_hud
DATABASE_URL=sqlite+aiosqlite:///./llm_hud.db

# Encryption key storage path (~/.llm-hud/secret.key by default)
# Leave blank to use the default
SECRET_KEY_PATH=

# CORS origins (space-separated). Add your frontend dev URL here.
CORS_ORIGINS=http://localhost:5173 http://localhost:4173
